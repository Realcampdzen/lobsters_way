# Кот Бро SMM — Environment Variables
# Скопируй в shared/.env и заполни реальными значениями

# OpenAI (для генерации комментов и контента)
OPENAI_API_KEY=sk-your-key-here

# Release/runtime layout
OPENCLAW_HOME=/Users/your-user/.openclaw-kot-bro
OPENCLAW_BIN=openclaw
OPENCLAW_RESTART_BIN=openclaw-restart
OPENCLAW_RELEASE_ADMIN_IDS=123456789

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHANNEL_ID=@your-channel
TELEGRAM_DISCUSSION_GROUP_ID=-100xxxxxxxxxx

# VK (опционально, на будущее)
VK_ACCESS_TOKEN=your-vk-token
VK_GROUP_ID=your-group-id

# Webhook
WEBHOOK_SECRET=generate-a-random-secret

# Модель
MODEL_NAME=gpt-4o
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=150

# Локальная распознавалка аудио (Whisper)
OPENAI_WHISPER_BASE_URL=http://your-whisper-host:port/v1

# Ollama (локальный embedder для memory search)
# Не нужен в .env — прописан в openclaw.json как http://host.docker.internal:11434/v1
